<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MangaReader</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/reader.css" asp-append-version="true" />
</head>

<body data-theme="dark">

    <header class="p-2 border-bottom bg-white">
        <div class="container d-flex justify-content-between align-items-center">
            <a asp-controller="Home" asp-action="Index" class="fw-bold text-decoration-none">
                MangaReader
            </a>

            <div>
                @ViewData["ChapterTitle"]
            </div>

            <div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="me-2">@User.Identity.Name</span>
                }
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

</body>
</html>