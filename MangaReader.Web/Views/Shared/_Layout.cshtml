<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MangaReader</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .app-shell {
            min-height: calc(100vh - 140px);
        }

        .footer-muted {
            color: #6c757d;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">MangaReader</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Manga" asp-action="Index">Каталог</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Author" asp-action="Dashboard">Мой кабинет</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Author" asp-action="Profile">Профиль</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-muted small me-2">
                                @User.Identity.Name
                            </span>

                            <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    Выйти
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-sm">
                                Войти
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">
                                Регистрация
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-shell">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top bg-white mt-4">
        <div class="container py-3 d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div class="footer-muted">
                © @DateTime.Now.Year MangaReader
            </div>
            <div class="footer-muted">
                Читай, создавай, публикуй
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>