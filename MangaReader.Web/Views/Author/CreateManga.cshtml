@model MangaReader.Web.ViewModels.Manga.CreateMangaViewModel

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h2 class="mb-1">Создать мангу</h2>
                        <p class="text-muted mb-0">Заполни основную информацию о проекте.</p>
                    </div>

                    <form asp-action="CreateManga" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Название</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Категории</label>

                            @if (Model.AvailableCategories.Any())
                            {
                                <div class="row">
                                    @foreach (var category in Model.AvailableCategories)
                                    {
                                        <div class="col-md-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="SelectedCategoryIds"
                                                       value="@category.Id"
                                                       id="cat_@category.Id"
                                                       @(Model.SelectedCategoryIds.Contains(category.Id) ? "checked" : null) />
                                                <label class="form-check-label" for="cat_@category.Id">
                                                    @category.Name
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Категории пока не добавлены.</p>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Обложка</label>
                            <input type="file" name="cover" class="form-control" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Создать</button>
                            <a asp-controller="Author" asp-action="Dashboard" class="btn btn-outline-secondary">
                                Назад
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>