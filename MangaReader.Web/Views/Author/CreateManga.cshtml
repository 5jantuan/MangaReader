@model MangaReader.Web.ViewModels.Manga.CreateMangaViewModel

<h2>Создать мангу</h2>

<form asp-action="CreateManga" method="post" enctype="multipart/form-data">
    <div>
        <label asp-for="Title">Название</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label asp-for="Description">Описание</label>
        <textarea asp-for="Description"></textarea>
    </div>

    <div>
        <label>Категории</label>
        @foreach (var category in Model.AvailableCategories)
        {
            <div>
                <input type="checkbox"
                       name="SelectedCategoryIds"
                       value="@category.Id"
                       @(Model.SelectedCategoryIds.Contains(category.Id) ? "checked" : null) />
                <span>@category.Name</span>
            </div>
        }
    </div>

    <div>
        <label>Обложка</label>
        <input type="file" name="cover" />
    </div>

    <button type="submit">Создать</button>
</form>