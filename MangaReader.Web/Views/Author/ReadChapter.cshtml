@model MangaReader.Domain.Entities.Chapter

@{
    Guid? preferredLanguageId = ViewBag.PreferredLanguageId as Guid?;
}

<h2 class="mb-4">@Model.Title</h2>

@foreach (var p in Model.Pages.OrderBy(x => x.Number))
{
    var bubbles = p.Bubbles?.OrderBy(b => b.Number).ToList() ?? new List<MangaReader.Domain.Entities.Bubble>();
    var pageContainerId = $"page-container-{p.Id}";
    var imageId = $"page-image-{p.Id}";
    var overlayId = $"page-overlay-{p.Id}";
    var originalLanguageId = Model.Manga.OriginalLanguageId;

    <div class="mb-5">
        <div id="@pageContainerId"
             class="reader-page-container"
             style="position: relative; display: inline-block; max-width: 100%;">
            
            <img id="@imageId"
                 src="@p.ImagePath"
                 class="reader-page-image"
                 style="max-width: 100%; height: auto; display: block;" />

            <div id="@overlayId"
                 class="reader-page-overlay"
                 style="position: absolute; inset: 0; pointer-events: none;">
                
                @if (bubbles.Any())
                {
                    @foreach (var bubble in bubbles)
                    {
                        var translations = bubble.Translations 
                            ?? Enumerable.Empty<MangaReader.Domain.Entities.BubbleTranslation>();

                        var textToShow = bubble.OriginalText;

                        if (preferredLanguageId.HasValue && preferredLanguageId.Value != originalLanguageId)
                        {
                            var translation = translations.FirstOrDefault(t => t.LanguageId == preferredLanguageId.Value);
                            textToShow = translation?.Text ?? bubble.OriginalText;
                        }

                        if (!string.IsNullOrWhiteSpace(textToShow))
                        {
                            <div class="bubble-box"
                                data-x="@bubble.X"
                                data-y="@bubble.Y"
                                data-width="@bubble.Width"
                                data-height="@bubble.Height"
                                style="
                                    position: absolute;
                                    background: rgba(255, 255, 255, 0.9);
                                    border: 1px solid rgba(0,0,0,0.12);
                                    border-radius: 8px;
                                    padding: 4px 6px;
                                    font-size: @(bubble.TranslationFontSize)px;
                                    line-height: 1.15;
                                    overflow: hidden;
                                    overflow-wrap: break-word;
                                    word-break: break-word;
                                    box-sizing: border-box;
                                    z-index: 2;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    text-align: center;
                                    pointer-events: auto;"
                                title="@textToShow">
                                @textToShow
                            </div>
                        }
                    }
                }
            </div>
        </div>

        <details class="mt-3">
            <summary>Отладочная информация</summary>

            <div class="card mt-2">
                <div class="card-body">
                    @if (bubbles.Any())
                    {
                        <ul class="mb-0">
                            @foreach (var bubble in bubbles)
                            {
                                <li>
                                    <strong>Original:</strong> @bubble.OriginalText
                                    <br />
                                    @foreach (var tr in bubble.Translations ?? Enumerable.Empty<MangaReader.Domain.Entities.BubbleTranslation>())
                                    {
                                        <span><strong>Translation:</strong> @tr.Text</span>
                                        <br />
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Баблов пока нет.</p>
                    }
                </div>
            </div>
        </details>
    </div>
}

<script>
    function updatePhraseBoxes() {
        const containers = document.querySelectorAll('.reader-page-container');

        containers.forEach(container => {
            const image = container.querySelector('.reader-page-image');
            const overlay = container.querySelector('.reader-page-overlay');
            const boxes = container.querySelectorAll('.bubble-box');

            if (!image || !overlay || !boxes.length) {
                return;
            }

            const displayedWidth = image.clientWidth;
            const displayedHeight = image.clientHeight;

            if (!displayedWidth || !displayedHeight) {
                return;
            }

            overlay.style.width = displayedWidth + 'px';
            overlay.style.height = displayedHeight + 'px';

            const naturalWidth = image.naturalWidth;
            const naturalHeight = image.naturalHeight;

            if (!naturalWidth || !naturalHeight) {
                return;
            }

            const scaleX = displayedWidth / naturalWidth;
            const scaleY = displayedHeight / naturalHeight;

            boxes.forEach(box => {
                const x = parseFloat(box.dataset.x || '0');
                const y = parseFloat(box.dataset.y || '0');
                const width = parseFloat(box.dataset.width || '0');
                const height = parseFloat(box.dataset.height || '0');

                box.style.left = (x * scaleX) + 'px';
                box.style.top = (y * scaleY) + 'px';
                box.style.width = Math.max(width * scaleX, 40) + 'px';
                box.style.minHeight = Math.max(height * scaleY, 20) + 'px';
                box.style.maxHeight = Math.max(height * scaleY * 2, 40) + 'px';
            });
        });
    }

    window.addEventListener('load', updatePhraseBoxes);
    window.addEventListener('resize', updatePhraseBoxes);
</script>