@model MangaReader.Domain.Entities.Chapter

@{
    Guid? preferredLanguageId = ViewBag.PreferredLanguageId as Guid?;
}

<h2 class="mb-4">@Model.Title</h2>

@foreach (var p in Model.Pages.OrderBy(x => x.Number))
{
    var phrases = p.Phrases?.ToList() ?? new List<MangaReader.Domain.Entities.Phrase>();

    <div class="mb-5">
        <div style="position: relative; display: inline-block; max-width: 100%;">
            <img src="@p.ImagePath"
                 style="max-width: 100%; height: auto; display: block;" />

            @if (phrases.Any())
            {
                @foreach (var phrase in phrases)
                {
                    var translations = phrase.PhraseTranslations ?? Enumerable.Empty<MangaReader.Domain.Entities.PhraseTranslation>();

                    var translation = translations.FirstOrDefault(t => preferredLanguageId.HasValue && t.LanguageId == preferredLanguageId.Value)
                                   ?? translations.FirstOrDefault();

                    if (translation != null)
                    {
                        <div style="
                            position: absolute;
                            left: @(phrase.X)px;
                            top: @(phrase.Y)px;
                            width: @(phrase.Width)px;
                            min-height: @(phrase.Height)px;
                            background: rgba(255, 255, 255, 0.85);
                            border: 1px solid rgba(0,0,0,0.15);
                            border-radius: 6px;
                            padding: 4px 6px;
                            font-size: 12px;
                            line-height: 1.2;
                            overflow-wrap: break-word;
                            word-break: break-word;
                            box-sizing: border-box;
                            z-index: 2;">
                            @translation.Text
                        </div>
                    }
                }
            }
        </div>

        <details class="mt-3">
            <summary>Отладочная информация</summary>

            <div class="card mt-2">
                <div class="card-body">
                    @if (phrases.Any())
                    {
                        <ul class="mb-0">
                            @foreach (var phrase in phrases)
                            {
                                <li>
                                    <strong>Original:</strong> @phrase.Text
                                    <br />
                                    @foreach (var tr in phrase.PhraseTranslations ?? Enumerable.Empty<MangaReader.Domain.Entities.PhraseTranslation>())
                                    {
                                        <span><strong>Translation:</strong> @tr.Text</span>
                                        <br />
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Фраз пока нет.</p>
                    }
                </div>
            </div>
        </details>
    </div>
}