@model MangaReader.Web.ViewModels.Author.AuthorDashboardViewModel

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div class="d-flex align-items-center gap-3">
        @if (!string.IsNullOrWhiteSpace(Model.AvatarPath))
        {
            <img src="@Model.AvatarPath"
                 style="width: 64px; height: 64px; object-fit: cover; border-radius: 50%;" />
        }
        else
        {
            <div class="bg-light d-flex align-items-center justify-content-center rounded-circle"
                 style="width: 64px; height: 64px;">
                <span class="text-muted">🙂</span>
            </div>
        }

        <div>
            <h2 class="mb-0">Кабинет автора</h2>
            <div class="text-muted">Добро пожаловать, @Model.UserName</div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a asp-controller="Author" asp-action="Profile" class="btn btn-outline-secondary">
            Мой профиль
        </a>
        <a asp-controller="Author" asp-action="CreateManga" class="btn btn-primary">
            Создать мангу
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="text-muted small">Проектов</div>
                <div class="fs-3 fw-bold">@Model.ProjectsCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="text-muted small">Глав</div>
                <div class="fs-3 fw-bold">@Model.ChaptersCount</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="text-muted small">Всего просмотров</div>
                <div class="fs-3 fw-bold">@Model.TotalViews</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Mangas.Any())
{
    <div class="row g-4">
        @foreach (var manga in Model.Mangas)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(manga.CoverUrl))
                    {
                        <img src="@manga.CoverUrl"
                             class="card-img-top"
                             style="height: 320px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center"
                             style="height: 320px;">
                            <span class="text-muted">Нет обложки</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@manga.Title</h5>

                        <p class="text-muted mb-2">👁 @manga.TotalViews просмотров</p>

                        @if (manga.Categories.Any())
                        {
                            <div class="mb-2">
                                @foreach (var category in manga.Categories)
                                {
                                    <span class="badge bg-secondary me-1 mb-1">@category</span>
                                }
                            </div>
                        }

                        <div class="mb-3">
                            <small class="text-muted">
                                Глав: @manga.Chapters.Count
                            </small>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <a asp-controller="Author"
                               asp-action="MangaDetails"
                               asp-route-mangaId="@manga.Id"
                               class="btn btn-sm btn-outline-primary">
                                Открыть
                            </a>

                            <a asp-controller="Author"
                               asp-action="CreateChapter"
                               asp-route-mangaId="@manga.Id"
                               class="btn btn-sm btn-primary">
                                Добавить главу
                            </a>
                        </div>

                        @if (manga.Chapters.Any())
                        {
                            <ul class="list-group list-group-flush mt-auto">
                                @foreach (var chapter in manga.Chapters.OrderByDescending(c => c.Number).Take(3))
                                {
                                    <li class="list-group-item px-0">
                                        <div class="fw-semibold">
                                            Глава @chapter.Number: @chapter.Title
                                        </div>
                                        <small class="text-muted">
                                            Страниц: @chapter.Pages.Count | Просмотров: @chapter.Views
                                        </small>
                                        <div class="mt-1">
                                            <a asp-controller="Author"
                                               asp-action="ReadChapter"
                                               asp-route-chapterId="@chapter.Id"
                                               class="btn btn-link btn-sm p-0">
                                                Читать
                                            </a>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted mt-auto mb-0">Глав пока нет.</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <h4 class="mb-2">У тебя пока нет проектов</h4>
            <p class="text-muted">Создай первую мангу и начни публиковать главы.</p>
            <a asp-controller="Author" asp-action="CreateManga" class="btn btn-primary">
                Создать мангу
            </a>
        </div>
    </div>
}