@model MangaReader.Web.ViewModels.Chapter.ReviewOcrChapterViewModel
@using System.Text.Json

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">@Model.ChapterTitle</h3>
            <p class="text-muted mb-0">Проверка OCR и баблов</p>
        </div>

        <a asp-action="ChapterStatus"
           asp-route-chapterId="@Model.ChapterId"
           class="btn btn-outline-secondary btn-sm">
            Назад к статусам
        </a>
    </div>

    <div class="row g-3">
        <div class="col-md-2">
            <div class="page-thumbnails">
                @foreach (var chapterPage in Model.Pages)
                {
                    var activeClass = chapterPage.PageId == Model.CurrentPageId ? "active-page" : "";

                    <a asp-action="ReviewOcrChapter"
                    asp-route-chapterId="@Model.ChapterId"
                    asp-route-pageId="@chapterPage.PageId"
                    class="thumb-card @activeClass">
                        <img src="@chapterPage.ImagePath" class="thumb-img" />
                        <div class="thumb-number">Стр. @chapterPage.Number</div>
                    </a>
                }
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>Страница @Model.CurrentPageNumber</h5>
                    <p class="text-muted">Статус: @Model.CurrentPageStatus</p>

                    <div id="ocrWrapper" class="ocr-image-wrapper">
                        <img src="@Model.CurrentImagePath"
                             id="ocrImage"
                             class="ocr-page-image" />
                        <div id="selectionBox" class="selection-box"></div> 

                        @foreach (var bubble in Model.Bubbles)
                        {
                            <div class="bubble-box"
                                data-bubble-id="@bubble.BubbleId"
                                data-text="@bubble.Text"
                                data-translation="@bubble.Translation"
                                data-x="@bubble.X"
                                data-y="@bubble.Y"
                                data-width="@bubble.Width"
                                data-height="@bubble.Height"
                                data-font-size="@bubble.TranslationFontSize"
                                title="@bubble.Text">

                                <div class="resize-handle"></div>

                                @if (!string.IsNullOrWhiteSpace(bubble.Translation))
                                {
                                    <div class="bubble-translation"
                                        style="font-size:@(bubble.TranslationFontSize)px">
                                        @bubble.Translation
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="GroupPageBubbles" method="post" class="mb-3">
                        <input type="hidden" name="pageId" value="@Model.CurrentPageId" />
                        <button type="submit" class="btn btn-warning w-100">
                            Пересформировать баблы страницы
                        </button>
                    </form>

                    <hr />

                    <div id="emptyPanel">
                        <p class="text-muted">
                            Нажми на бабл на странице, чтобы редактировать его текст и координаты.
                        </p>
                    </div>

                    <div id="editBubblePanel" style="display:none;">
                        <h5>Редактировать бабл</h5>

                        <form asp-action="UpdateBubbleReview" method="post">
                            <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                            <input type="hidden" name="pageId" value="@Model.CurrentPageId" />
                            <input type="hidden" id="bubbleId" name="bubbleId" />

                            <div class="mb-2">
                                <label class="form-label">Текст бабла</label>
                                <textarea id="bubbleText"
                                          name="text"
                                          class="form-control"
                                          rows="5"></textarea>
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Перевод</label>
                                <textarea id="bubbleTranslation"
                                        name="translation"
                                        class="form-control"
                                        rows="4"></textarea>
                            </div>

                            <div class="row">
                                <div class="col-6 mb-2">
                                    <label class="form-label">X</label>
                                    <input id="bubbleX" name="x" class="form-control" />
                                </div>

                                <div class="col-6 mb-2">
                                    <label class="form-label">Y</label>
                                    <input id="bubbleY" name="y" class="form-control" />
                                </div>

                                <div class="col-6 mb-2">
                                    <label class="form-label">Width</label>
                                    <input id="bubbleWidth" name="width" class="form-control" />
                                </div>

                                <div class="col-6 mb-3">
                                    <label class="form-label">Height</label>
                                    <input id="bubbleHeight" name="height" class="form-control" />
                                </div>
                                <div class="col-6 mb-3">
                                    <label class="form-label">Размер шрифта</label>
                                    <input id="bubbleFontSize" name="translationFontSize" class="form-control" />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-success w-100">
                                Сохранить бабл
                            </button>
                            <form asp-action="DeleteBubble" method="post" class="mt-2">
                                <input type="hidden" id="deleteBubbleId" name="bubbleId" />
                                <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                                <input type="hidden" name="pageId" value="@Model.CurrentPageId" />

                                <button type="submit" class="btn btn-danger w-100">
                                    Удалить бабл
                                </button>
                            </form>
                        </form>
                    </div>

                    <hr />

                    <h5>Добавить новый бабл</h5>

                    <p class="text-muted small">
                        Выдели область на странице мышкой, введи текст и сохрани.
                    </p>

                    <form asp-action="AddManualBubble" method="post" class="mb-3">
                        <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                        <input type="hidden" name="pageId" value="@Model.CurrentPageId" />

                        <input type="hidden" id="manualBubbleX" name="x" />
                        <input type="hidden" id="manualBubbleY" name="y" />
                        <input type="hidden" id="manualBubbleWidth" name="width" />
                        <input type="hidden" id="manualBubbleHeight" name="height" />

                        <textarea name="text" class="form-control mb-2" rows="3" required></textarea>

                        <button type="submit" class="btn btn-outline-primary w-100">
                            Добавить бабл
                        </button>
                    </form>

                    <hr />

                    <form asp-action="StartChapterTranslation" method="post">
                        <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                        <button type="submit" class="btn btn-primary w-100">
                            Запустить перевод всей главы
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-thumbnails {
        max-height: 82vh;
        overflow-y: auto;
        padding-right: 6px;
    }

    .thumb-card {
        display: block;
        text-decoration: none;
        color: inherit;
        border: 2px solid transparent;
        border-radius: 10px;
        padding: 8px;
        margin-bottom: 12px;
        background: #f8f9fa;
    }

    .thumb-card:hover {
        background: #eef3ff;
    }

    .active-page {
        border-color: #dc3545;
        background: #fff0f0;
    }

    .thumb-img {
        width: 100%;
        border-radius: 6px;
        display: block;
    }

    .thumb-number {
        text-align: center;
        font-size: 13px;
        margin-top: 6px;
    }

    .ocr-image-wrapper {
        position: relative;
        display: inline-block;
        max-width: 100%;
        border: 1px solid #ddd;
        border-radius: 8px;
        overflow: hidden;
    }

    .ocr-page-image {
        display: block;
        max-width: 100%;
        height: auto;
    }

    .bubble-box {
        position: absolute;
        border: 2px solid red;
        background-color: rgba(255, 0, 0, 0.15);
        z-index: 10;
        cursor: pointer;
    }

    .bubble-box-selected {
        border: 3px solid blue;
        background-color: rgba(0, 0, 255, 0.18);
    }

    .bubble-translation {
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.88);
        color: black;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4px;
        font-size: 14px;
    }

    .selection-box {
        position: absolute;
        border: 2px dashed blue;
        background-color: rgba(0, 0, 255, 0.12);
        display: none;
        z-index: 30;
        pointer-events: none;
    }

    .resize-handle {
        position: absolute;
        right: -5px;
        bottom: -5px;
        width: 12px;
        height: 12px;
        background: blue;
        cursor: nwse-resize;
        z-index: 50;
    }
</style>

<script>
    const bubbles = @Html.Raw(JsonSerializer.Serialize(Model.Bubbles));

    const img = document.getElementById("ocrImage");
    const boxes = document.querySelectorAll(".bubble-box");

    function drawBoxes() {
        const scaleX = img.clientWidth / img.naturalWidth;
        const scaleY = img.clientHeight / img.naturalHeight;

        bubbles.forEach((bubble, index) => {
            const box = boxes[index];
            if (!box) return;

            box.style.left = (bubble.X * scaleX) + "px";
            box.style.top = (bubble.Y * scaleY) + "px";
            box.style.width = (bubble.Width * scaleX) + "px";
            box.style.height = (bubble.Height * scaleY) + "px";
        });
    }

    document.querySelectorAll(".bubble-box").forEach(box => {
        box.addEventListener("click", function (e) {
            let selectedBox = null;
            let isDraggingBubble = false;
            let isResizingBubble = false;

            let dragStartX = 0;
            let dragStartY = 0;
            let startLeft = 0;
            let startTop = 0;
            let startWidth = 0;
            let startHeight = 0;

            function fillBubbleForm(box) {
                document.getElementById("emptyPanel").style.display = "none";
                document.getElementById("editBubblePanel").style.display = "block";

                document.getElementById("bubbleId").value = box.dataset.bubbleId;
                document.getElementById("deleteBubbleId").value = box.dataset.bubbleId;
                document.getElementById("bubbleText").value = box.dataset.text;
                document.getElementById("bubbleTranslation").value = box.dataset.translation || "";

                document.getElementById("bubbleX").value = box.dataset.x;
                document.getElementById("bubbleY").value = box.dataset.y;
                document.getElementById("bubbleWidth").value = box.dataset.width;
                document.getElementById("bubbleHeight").value = box.dataset.height;
                document.getElementById("bubbleFontSize").value = box.dataset.fontSize || "14";
            }

            function updateFormFromBox(box) {
                const scaleX = img.naturalWidth / img.clientWidth;
                const scaleY = img.naturalHeight / img.clientHeight;

                const x = parseFloat(box.style.left) * scaleX;
                const y = parseFloat(box.style.top) * scaleY;
                const width = parseFloat(box.style.width) * scaleX;
                const height = parseFloat(box.style.height) * scaleY;

                box.dataset.x = x.toFixed(2);
                box.dataset.y = y.toFixed(2);
                box.dataset.width = width.toFixed(2);
                box.dataset.height = height.toFixed(2);

                document.getElementById("bubbleX").value = x.toFixed(2);
                document.getElementById("bubbleY").value = y.toFixed(2);
                document.getElementById("bubbleWidth").value = width.toFixed(2);
                document.getElementById("bubbleHeight").value = height.toFixed(2);
            }

            document.querySelectorAll(".bubble-box").forEach(box => {
                box.addEventListener("mousedown", function (e) {
                    e.stopPropagation();

                    selectedBox = box;

                    document.querySelectorAll(".bubble-box").forEach(b => {
                        b.classList.remove("bubble-box-selected");
                    });

                    box.classList.add("bubble-box-selected");
                    fillBubbleForm(box);

                    dragStartX = e.clientX;
                    dragStartY = e.clientY;

                    startLeft = parseFloat(box.style.left) || 0;
                    startTop = parseFloat(box.style.top) || 0;
                    startWidth = parseFloat(box.style.width) || 0;
                    startHeight = parseFloat(box.style.height) || 0;

                    if (e.target.classList.contains("resize-handle")) {
                        isResizingBubble = true;
                    } else {
                        isDraggingBubble = true;
                    }
                });
            });

            document.addEventListener("mousemove", function (e) {
                if (!selectedBox) return;

                const dx = e.clientX - dragStartX;
                const dy = e.clientY - dragStartY;

                if (isDraggingBubble) {
                    selectedBox.style.left = (startLeft + dx) + "px";
                    selectedBox.style.top = (startTop + dy) + "px";
                    updateFormFromBox(selectedBox);
                }

                if (isResizingBubble) {
                    const newWidth = Math.max(10, startWidth + dx);
                    const newHeight = Math.max(10, startHeight + dy);

                    selectedBox.style.width = newWidth + "px";
                    selectedBox.style.height = newHeight + "px";
                    updateFormFromBox(selectedBox);
                }
            });

            document.addEventListener("mouseup", async function () {

                if ((isDraggingBubble || isResizingBubble) && selectedBox) {
                    await autoSaveBubble(selectedBox);
                }

                isDraggingBubble = false;
                isResizingBubble = false;
            });
        });
    });

    if (img.complete) {
        drawBoxes();
    } else {
        img.onload = drawBoxes;
    }

    window.addEventListener("resize", drawBoxes);

    const wrapper = document.getElementById("ocrWrapper");
    const selectionBox = document.getElementById("selectionBox");

    let isSelecting = false;
    let startX = 0;
    let startY = 0;

    wrapper.addEventListener("mousedown", function (e) {
        if (e.target !== img) return;

        const rect = img.getBoundingClientRect();

        isSelecting = true;
        startX = e.clientX - rect.left;
        startY = e.clientY - rect.top;

        selectionBox.style.left = startX + "px";
        selectionBox.style.top = startY + "px";
        selectionBox.style.width = "0px";
        selectionBox.style.height = "0px";
        selectionBox.style.display = "block";
    });

    wrapper.addEventListener("mousemove", function (e) {
        if (!isSelecting) return;

        const rect = img.getBoundingClientRect();

        const currentX = e.clientX - rect.left;
        const currentY = e.clientY - rect.top;

        const left = Math.min(startX, currentX);
        const top = Math.min(startY, currentY);
        const width = Math.abs(currentX - startX);
        const height = Math.abs(currentY - startY);

        selectionBox.style.left = left + "px";
        selectionBox.style.top = top + "px";
        selectionBox.style.width = width + "px";
        selectionBox.style.height = height + "px";
    });

    wrapper.addEventListener("mouseup", function () {
        if (!isSelecting) return;

        isSelecting = false;

        const boxLeft = parseFloat(selectionBox.style.left);
        const boxTop = parseFloat(selectionBox.style.top);
        const boxWidth = parseFloat(selectionBox.style.width);
        const boxHeight = parseFloat(selectionBox.style.height);

        if (boxWidth < 5 || boxHeight < 5) return;

        const scaleX = img.naturalWidth / img.clientWidth;
        const scaleY = img.naturalHeight / img.clientHeight;

        document.getElementById("manualBubbleX").value = (boxLeft * scaleX).toFixed(2);
        document.getElementById("manualBubbleY").value = (boxTop * scaleY).toFixed(2);
        document.getElementById("manualBubbleWidth").value = (boxWidth * scaleX).toFixed(2);
        document.getElementById("manualBubbleHeight").value = (boxHeight * scaleY).toFixed(2);
    });

    async function autoSaveBubble(box) {
        const formData = new FormData();

        formData.append("bubbleId", box.dataset.bubbleId);
        formData.append("x", box.dataset.x);
        formData.append("y", box.dataset.y);
        formData.append("width", box.dataset.width);
        formData.append("height", box.dataset.height);

        await fetch("/Author/UpdateBubblePosition", {
            method: "POST",
            body: formData
        });
    }
</script>