@model MangaReader.Web.ViewModels.Author.EditAuthorProfileViewModel

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h2 class="mb-1">Редактировать профиль</h2>
                        <p class="text-muted mb-0">Обнови информацию о себе и свои ссылки.</p>
                    </div>

                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">Аватар</label>
                            <input type="file" name="avatar" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="About" class="form-label">О себе</label>
                            <textarea asp-for="About" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="About" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TelegramUrl" class="form-label">Telegram</label>
                            <input asp-for="TelegramUrl" class="form-control" />
                            <span asp-validation-for="TelegramUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InstagramUrl" class="form-label">Instagram</label>
                            <input asp-for="InstagramUrl" class="form-control" />
                            <span asp-validation-for="InstagramUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TikTokUrl" class="form-label">TikTok</label>
                            <input asp-for="TikTokUrl" class="form-control" />
                            <span asp-validation-for="TikTokUrl" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Сохранить</button>
                            <a asp-controller="Author"
                               asp-action="Profile"
                               class="btn btn-outline-secondary">
                                Назад
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>