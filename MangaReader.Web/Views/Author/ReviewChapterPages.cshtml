@model MangaReader.Web.ViewModels.Chapter.ReviewChapterPagesViewModel

<div class="container py-4">
    <div class="mb-4">
        <h2>Проверка страниц</h2>
        <p class="text-muted">
            Глава @Model.ChapterNumber: @Model.ChapterTitle
        </p>
    </div>

    <div class="row g-4">
        @foreach (var chapterPage in Model.Pages)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card shadow-sm h-100">
                    <img src="@chapterPage.ImagePath"
                        class="card-img-top"
                        style="height: 320px; object-fit: cover;" />

                    <div class="card-body">
                        <h6 class="card-title">Страница @chapterPage.Number</h6>

                        <form asp-action="DeleteChapterPage" method="post">
                            <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                            <input type="hidden" name="pageId" value="@chapterPage.PageId" />

                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Удалить
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-action="AddChapterPages"
           asp-route-chapterId="@Model.ChapterId"
           class="btn btn-outline-primary">
            Добавить страницы
        </a>

        <form asp-action="ConfirmChapterPages" method="post">
            <input type="hidden" name="chapterId" value="@Model.ChapterId" />
            <button type="submit" class="btn btn-success">
                Подтвердить и запустить OCR
            </button>
        </form>
    </div>
</div>