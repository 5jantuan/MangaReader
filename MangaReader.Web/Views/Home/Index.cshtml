@{
    ViewData["Title"] = "Главная";
}

<div class="container py-5">
    <div class="row align-items-center g-5 mb-5">
        <div class="col-lg-6">
            <span class="badge bg-dark-subtle text-dark mb-3 px-3 py-2">
                MangaReader
            </span>

            <h1 class="display-5 fw-bold mb-3">
                Читай мангу, публикуй главы и управляй своими проектами
            </h1>

            <p class="lead text-muted mb-4">
                MangaReader — это платформа, где автор может загружать мангу, добавлять главы,
                следить за просмотрами и оформлять свой профиль, а читатель — находить новые тайтлы и читать их онлайн.
            </p>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Manga" asp-action="Index" class="btn btn-primary btn-lg">
                    Перейти в каталог
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Author" asp-action="Dashboard" class="btn btn-outline-secondary btn-lg">
                        Мой кабинет
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-lg">
                        Начать
                    </a>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="bg-light d-flex align-items-center justify-content-center"
                     style="min-height: 360px;">
                    <div class="text-center p-4">
                        <div class="fs-1 mb-3"></div>
                        <h4 class="fw-semibold">Твоя манга — в одном месте</h4>
                        <p class="text-muted mb-0">
                            Загружай обложки, главы и страницы, оформляй профиль автора
                            и развивай свою библиотеку.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="fs-2 mb-3"></div>
                    <h5 class="card-title">Для авторов</h5>
                    <p class="card-text text-muted">
                        Создавай мангу, добавляй главы, загружай страницы и управляй своими проектами через удобный кабинет автора.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="fs-2 mb-3"></div>
                    <h5 class="card-title">Статистика</h5>
                    <p class="card-text text-muted">
                        Отслеживай просмотры глав и манги, анализируй интерес аудитории и развивай свои работы.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="fs-2 mb-3"></div>
                    <h5 class="card-title">Каталог и чтение</h5>
                    <p class="card-text text-muted">
                        Читатели могут открывать каталог, находить мангу по категориям и читать главы в удобном режиме.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-lg-5 text-center">
            <h3 class="mb-3">Готова продолжать развитие проекта?</h3>
            <p class="text-muted mb-4">
                Следующий шаг — публикация манги, улучшение интерфейса и расширение возможностей для читателей и авторов.
            </p>

            <div class="d-flex justify-content-center flex-wrap gap-2">
                <a asp-controller="Manga" asp-action="Index" class="btn btn-primary">
                    Открыть каталог
                </a>
                <a asp-controller="Author" asp-action="Dashboard" class="btn btn-outline-secondary">
                    Перейти в кабинет
                </a>
            </div>
        </div>
    </div>
</div>