@model MangaReader.Domain.Entities.Manga

<h2>@Model.Title</h2>

@if (Model.Covers.Any())
{
    var cover = Model.Covers.FirstOrDefault(c => c.IsPinned) ?? Model.Covers.First();

    <div style="margin-bottom: 20px;">
        <img src="@cover.Path" style="max-width: 250px; height: auto;" />
    </div>
}

<p>@Model.Description</p>

@if (Model.Categories.Any())
{
    <p>
        <strong>Категории:</strong>
        @string.Join(", ", Model.Categories.Select(c => c.Name))
    </p>
}

<p><strong>Всего глав:</strong> @Model.Chapters.Count</p>
<p><strong>Всего просмотров:</strong> @Model.Chapters.Sum(c => c.Views)</p>

<h3>Главы</h3>

<ul>
    @foreach (var chapter in Model.Chapters.OrderBy(c => c.Number))
    {
        <li>
            Глава @chapter.Number: @chapter.Title
            (страниц: @chapter.Pages.Count)
            (просмотров: @chapter.Views)

            <a asp-controller="Author"
               asp-action="ReadChapter"
               asp-route-chapterId="@chapter.Id">
                Читать
            </a>
        </li>
    }
</ul>